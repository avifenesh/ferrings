    "check:main-health": "node scripts/check-main-health.js",
    "check:workflows": "node scripts/check-workflows.js",
    "check:published": "node scripts/check-published.js",
    "check:registry-install": "node scripts/check-registry-install.js",
    "check:release-repository": "node scripts/check-release-repository.js",
