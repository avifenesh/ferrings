    "bench:tcp": "node benchmark/tcp-echo.js",
    "bench:high": "node benchmark/high-concurrency.js",
    "bench:syscalls": "node benchmark/syscalls.js",
    "example:http": "node examples/http-fixed.js",
    "example:tcp": "node examples/tcp-echo.js"
